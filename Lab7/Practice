public class Dog
{
    // Поля 
    protected string _name;
    protected string _color;
    protected int _age;
    
    // Свойтсва
    public string Name => _name;
    public string Color => _color;
    public int Age => _age;
    
    //Конструктор
    public Dog(string name, int age)
    {
        _name = name;
        _age = age;
    }

    public virtual void Method()
    {
        Console.WriteLine("Method in class Dog");
    }

    public void Print()
    {
        Console.WriteLine($"Name: {_name}, Age: {_age}");
    }
}

public class Pitbul : Dog
{
    private string _breed;
    private bool _isPitbul;

    public string Breed => _breed;
    
    public Pitbul(string name, int age, string breed) : base(name, age)
    {
        _breed = breed;
        _isPitbul = true;
    }

    public Pitbul(string name, int age, string breed, bool isValid) : this(name, age, breed)
    {
        _isPitbul = isValid;
    }

    public override void Method()
    {
        Console.WriteLine("Mehtod in class Pitbul");
    }
    public void Print()
    {
        Console.WriteLine($"Name: {_name}, Age: {_age}, Breed: {_breed}");
    }
}
